{
  "info": {
    "_postman_id": "community-response-hub-api",
    "name": "Community Response Hub API",
    "description": "Local API tests for Community Response Hub (backend/src).\n\n**Setup:**\n1. `docker-compose up -d`\n2. Copy `backend/.env.example` to `backend/.env.local` and set Cloudinary credentials\n3. `cd backend && npm run dev`\n4. Import `CRH-Local.postman_environment.json` and select **CRH Local**\n5. Run **Auth → Login (Admin)** first to set `accessToken`\n\nSeed admin: `admin@example.com` / `Admin123!`\n\n**Media:** Run **Complaints → List** or **Create Complaint** to set `complaintId`, then **Complaint Media → Upload** (pick a file in the Body tab).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1"
    }
  ],
  "item": [
    {
      "name": "Setup (no auth)",
      "item": [
        {
          "name": "API Root",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}"
          }
        },
        {
          "name": "Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "DB Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/db"
          }
        },
        {
          "name": "DB Stats",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/db/stats"
          }
        },
        {
          "name": "List Categories (public)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Resident)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.tokens?.accessToken) {",
                  "  pm.environment.set('accessToken', json.data.tokens.accessToken);",
                  "  pm.environment.set('refreshToken', json.data.tokens.refreshToken);",
                  "}",
                  "pm.test('Registration successful', () => {",
                  "  pm.response.to.have.status(201);",
                  "  pm.expect(json.success).to.eql(true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Resident\",\n  \"email\": \"test.resident@example.com\",\n  \"password\": \"Test1234\",\n  \"phoneNumber\": \"09171234567\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.tokens?.accessToken) {",
                  "  pm.environment.set('accessToken', json.data.tokens.accessToken);",
                  "  pm.environment.set('refreshToken', json.data.tokens.refreshToken);",
                  "}",
                  "pm.test('Login successful', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.tokens.accessToken).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login (custom)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.tokens?.accessToken) {",
                  "  pm.environment.set('accessToken', json.data.tokens.accessToken);",
                  "  pm.environment.set('refreshToken', json.data.tokens.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"your@email.com\",\n  \"password\": \"yourpassword\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.accessToken) {",
                  "  pm.environment.set('accessToken', json.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh-token"
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
      }
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Category by ID",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Create Category (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Test Category\",\n  \"description\": \"Created from Postman\"\n}"
            },
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Update Category (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Updated Category\",\n  \"description\": \"Updated from Postman\"\n}"
            },
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete Category (admin)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
      }
    },
    {
      "name": "Users (admin)",
      "item": [
        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.users?.length) {",
                  "  pm.environment.set('userId', json.users[0].user_id);",
                  "  const responder = json.users.find(u => u.role_name === 'responder');",
                  "  if (responder) pm.environment.set('assignedToUserId', responder.user_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users?roleId=&isActive=&verificationStatus=",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "roleId", "value": "", "description": "Optional filter" },
                { "key": "isActive", "value": "", "description": "true | false" },
                { "key": "verificationStatus", "value": "", "description": "pending | approved | rejected" }
              ]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"09998887777\",\n  \"address\": \"Block 1, Sample Subdivision\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Activate User",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}/activate"
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/users/{{userId}}/deactivate"
          }
        },
        {
          "name": "Review Verification (admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verificationStatus\": \"approved\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/verification/review"
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
      }
    },
    {
      "name": "Users (resident)",
      "item": [
        {
          "name": "Submit Verification (me)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verificationType\": \"ID\",\n  \"documentUrl\": \"https://example.com/sample-id.jpg\",\n  \"address\": \"Block 10, Barangay Example\"\n}"
            },
            "url": "{{baseUrl}}/users/me/verification"
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
      }
    },
    {
      "name": "Complaints",
      "item": [
        {
          "name": "List Complaints",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.complaints?.length) {",
                  "  pm.environment.set('complaintId', json.complaints[0].complaint_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/complaints?status=&categoryId=&priorityLevel=&assignedToUserId=",
              "host": ["{{baseUrl}}"],
              "path": ["complaints"],
              "query": [
                { "key": "status", "value": "", "description": "pending | assigned | resolved | ..." },
                { "key": "categoryId", "value": "" },
                { "key": "priorityLevel", "value": "", "description": "low | normal | high | urgent" },
                { "key": "assignedToUserId", "value": "" }
              ]
            }
          }
        },
        {
          "name": "My Complaints (resident)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/complaints/my"
          }
        },
        {
          "name": "Get Complaint by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/complaints/{{complaintId}}"
          }
        },
        {
          "name": "Create Complaint",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.complaint_id) {",
                  "  pm.environment.set('complaintId', json.data.complaint_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": {{categoryId}},\n  \"title\": \"Noise complaint from Postman\",\n  \"description\": \"Loud music after 10pm near Block 4.\",\n  \"locationText\": \"Block 4\",\n  \"priorityLevel\": \"normal\"\n}"
            },
            "url": "{{baseUrl}}/complaints"
          }
        },
        {
          "name": "Update Complaint Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"complaintStatus\": \"in_progress\",\n  \"remarks\": \"Officer dispatched (Postman test)\"\n}"
            },
            "url": "{{baseUrl}}/complaints/{{complaintId}}/status"
          }
        },
        {
          "name": "Assign Complaint",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assignedToUserId\": \"{{assignedToUserId}}\"\n}"
            },
            "url": "{{baseUrl}}/complaints/{{complaintId}}/assign",
            "description": "Run **List Users** first to set `assignedToUserId` (responder UUID)."
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
      }
    },
    {
      "name": "Complaint Media",
      "item": [
        {
          "name": "Upload Complaint Media",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.length) {",
                  "  pm.environment.set('mediaId', json.data[0].media_id);",
                  "}",
                  "pm.test('Media uploaded', () => {",
                  "  pm.response.to.have.status(201);",
                  "  pm.expect(json.status).to.eql('ok');",
                  "  pm.expect(json.data[0].media_url).to.include('res.cloudinary.com');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "description": "Image or video (max 10MB). Click Select Files.",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{baseUrl}}/complaints/{{complaintId}}/media",
            "description": "Uploads to Cloudinary and saves URL in `complaint_media`.\n\n1. Set `complaintId` via **List Complaints** or **Create Complaint**\n2. Body → form-data → **files** → Select Files (jpg/png/mp4, etc.)\n3. Do not set Content-Type manually (Postman adds multipart boundary)."
          }
        },
        {
          "name": "Upload Complaint Media (multiple files)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.length) {",
                  "  pm.environment.set('mediaId', json.data[json.data.length - 1].media_id);",
                  "}",
                  "pm.test('Media uploaded', () => {",
                  "  pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": [],
                  "description": "First file"
                },
                {
                  "key": "files",
                  "type": "file",
                  "src": [],
                  "description": "Second file (optional)"
                }
              ]
            },
            "url": "{{baseUrl}}/complaints/{{complaintId}}/media",
            "description": "Same field name `files` repeated (max 5 per request)."
          }
        },
        {
          "name": "List Complaint Media",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.length) {",
                  "  pm.environment.set('mediaId', json.data[0].media_id);",
                  "}",
                  "pm.test('Media list retrieved', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/complaints/{{complaintId}}/media",
            "description": "Returns all media for the complaint (`media_url`, `media_type`, etc.)."
          }
        },
        {
          "name": "Delete Complaint Media",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Media deleted', () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/complaints/{{complaintId}}/media/{{mediaId}}",
            "description": "Removes DB row only (Cloudinary asset not deleted in v1). Run **Upload** or **List** first to set `mediaId`."
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
      }
    },
    {
      "name": "Activity Logs",
      "item": [
        {
          "name": "Get Logs by Complaint",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/activity-logs/complaint/{{complaintId}}"
          }
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
      }
    }
  ]
}
